# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
KNOWLEDGE_BASE_NAME=agent-knowledge

# Authentication - use ONE of the following:
# Option 1: API Key (not recommended for production)
AZURE_SEARCH_API_KEY=your-api-key-here

# Option 2: Managed Identity (leave AZURE_SEARCH_API_KEY empty to use DefaultAzureCredential)
# Ensure you're logged in: az login

# Query
QUERY=What information is available in this knowledge base?
